# APP
APP_NAME=GasQ
ENV=dev
DEBUG=true

# API
API_PREFIX=/api

# SECURITY / JWT
# In real .env files, set a long random secret (32+ characters)
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# DATABASE (PostgreSQL)
# Local example
DATABASE_URL=postgresql+asyncpg://gasq:gasq@localhost:5432/gasq

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# QUEUE / ETA defaults
DEFAULT_SEARCH_RADIUS_KM=10
DEFAULT_AVG_DRIVE_SPEED_KMH=30

# REDIS (optional)
REDIS_URL=redis://localhost:6379/0

# ESKIZ SMS (optional)
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_FROM=4546

# FIREBASE CLOUD MESSAGING (optional)
# Path to service account json file
FCM_SERVICE_ACCOUNT_PATH=

# PAYMENTS (placeholders)
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=