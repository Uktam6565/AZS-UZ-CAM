# APP
APP_NAME=GasQ
ENV=dev
DEBUG=true

# API
API_PREFIX=/api

# SECURITY / JWT
# В .env (НЕ в example) поставь длинный случайный ключ (32+ символов)
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# DATABASE (PostgreSQL)
# Пример для локального Postgres
DATABASE_URL=postgresql+asyncpg://gasq:gasq@localhost:5432/gasq

# CORS (если фронтенд отдельно)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# QUEUE / ETA defaults
DEFAULT_SEARCH_RADIUS_KM=10
DEFAULT_AVG_DRIVE_SPEED_KMH=30

# REDIS (опционально, если подключим позже)
REDIS_URL=redis://localhost:6379/0

# ESKIZ SMS (Uzbekistan) (опционально)
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
# sender / short code
ESKIZ_FROM=4546

# FIREBASE CLOUD MESSAGING (опционально)
# путь к файлу ключа сервис-аккаунта (json)
FCM_SERVICE_ACCOUNT_PATH=

# PAYMENTS (placeholders)
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=